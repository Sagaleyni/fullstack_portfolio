# ============================================================
# .env — Variables d'environnement du backend
# ⚠️  NE JAMAIS COMMITTER CE FICHIER SUR GITHUB
#     Ajoute .env dans ton .gitignore !
# ============================================================

# Port sur lequel le serveur Express écoute
PORT=5000

# URL de connexion à MongoDB
# En local     : mongodb://localhost:27017/portfolio
# En Docker    : mongodb://mongo:27017/portfolio  (mongo = nom du service Docker)
MONGO_URI=mongodb://mongo:27017/portfolio

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173
